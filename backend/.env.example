# ── Server ──
PORT=5000
NODE_ENV=development

# ── Database ──
MONGO_URI=mongodb://127.0.0.1:27017/lumina_ai

# ── Auth secrets (use long random strings; >=32 chars required in production) ──
# Generate with:  openssl rand -hex 32
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# ── Email (Nodemailer / Gmail SMTP) ──
# EMAIL_APP_PASSWORD must be a Gmail "App Password", not your account password.
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD="your_gmail_app_password"
# Optional SMTP overrides (defaults shown)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# ── Redis (BullMQ queue) ──
# Local Docker:  docker run -d -p 6379:6379 redis
# Managed/TLS providers use a rediss:// URL.
REDIS_URL=redis://localhost:6379

# ── Google Gemini ──
GEMINI_API_KEY=your_gemini_api_key
# Optional: override the model (defaults to gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest

# ── Frontend origin (CORS + WebSocket Origin allowlist) ──
FRONTEND_URL=http://localhost:3000
