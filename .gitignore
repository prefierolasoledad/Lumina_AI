# Root level dependencies
node_modules/

# Ignore local environment files everywhere
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Ignore frontend build directories
veda_ai/.next/
veda_ai/out/
veda_ai/build/
veda_ai/tsconfig.tsbuildinfo
veda_ai/next-env.d.ts

# Ignore backend build directories
veda_ai_backend/dist/

# Yarn PnP & Yarn Berry (if used)
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing & deployment
coverage/
.vercel/

# Ignore IDE settings & OS specific files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.pem

# Ignore BullMQ & node specific temp files
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
